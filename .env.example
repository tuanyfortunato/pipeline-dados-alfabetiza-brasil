# Copie para .env e preencha (o .env não é versionado)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/sua-chave.json
GCP_PROJECT_ID=seu-project-id

# Raiz do data lake: ./data em desenvolvimento, s3://<bucket> na promoção
LAKE_PATH=./data

# --- AWS (só nos modos de nuvem: carga no S3 e producer --destino kinesis) ---
# No Learner Lab, cole aqui o bloco de "AWS Details" da sessão (expira ~4h) OU
# use ~/.aws/credentials. boto3/s3fs leem as três variáveis abaixo.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_DEFAULT_REGION=us-east-1
