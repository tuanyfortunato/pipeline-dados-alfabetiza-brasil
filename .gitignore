# Credenciais GCP/AWS - NUNCA versionar
credentials/
*.json
!docs/**/*.json
.env

# Ambiente Python
.venv*/
venv/
__pycache__/
*.pyc

# Spark / Hadoop (ambiente local de streaming)
tools/
spark-warehouse/
metastore_db/
derby.log
*/_spark_metadata/
*/_checkpoint/

# Terraform (state e tfvars podem conter segredos; o lock file é versionado)
terraform/.terraform/
*.tfstate
*.tfstate.*
terraform/*.tfvars
!terraform/terraform.tfvars.example
terraform/backend.hcl
!terraform/backend.hcl.example

# Dados e logs locais (não versionar dados brutos, só código)
data/
logs/*.json
*.parquet
*.csv

# Notebooks - checkpoints
.ipynb_checkpoints/

# SO / IDE
.DS_Store
.vscode/
docs/teste/*