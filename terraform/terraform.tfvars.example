# Copie para terraform.tfvars e ajuste. O tfvars real é gitignorado.

# nome global único - troque o sufixo pelo seu
bucket_name = "alfabetiza-brasil-datalake-teste"

# projeto GCP da extração do BigQuery (o mesmo do .env)
gcp_project_id = "seu-project-id"

# recebe o alarme de falha da esteira/streaming - confirme a inscrição no
# e-mail (SNS manda um link de confirmação assim que o apply criar o topico)
alert_email = "seu-email@exemplo.com"
